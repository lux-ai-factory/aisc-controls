# Postgres — defaults match the bundled docker-compose.yml so `npm run dev`
# can spin up a fresh DB for you. Override if you have your own Postgres.
DATABASE_URL="postgresql://aisc:aisc@localhost:5444/aisc?schema=public"

# PDF report renderer (bundled services/pdf_renderer). The submission
# "Download report (PDF)" action POSTs to this service. The default matches the
# bundled docker-compose.yml; override only if you run the renderer elsewhere.
PDF_RENDERER_URL="http://localhost:8005"

# Feature flags. Set to "true" to enable.
#   AISC_ENABLE_TEMPLATE_EDITOR — exposes the per-checklist "Edit template"
#     action on the library page (checklists/[id]/review). Hidden by default;
#     intended for catalogue admins, not end users answering checklists.
AISC_ENABLE_TEMPLATE_EDITOR=""
