# Postgres — defaults match the bundled docker-compose.yml so `npm run dev`
# can spin up a fresh DB for you. Override if you have your own Postgres.
DATABASE_URL="postgresql://vera:vera@localhost:5444/vera?schema=public"

# LLMFactory — the bundled service in services/llm_factory/. The default URL
# below points at the docker-compose container; start it with `npm run llm:up`
# when you want to ingest new questionnaires. The browse-only flow does not
# need it.
LLM_FACTORY_URL="http://localhost:5001"
LLM_MODEL="claude-opus-4-7"

# Provider keys consumed by the bundled LLMFactory (read by docker-compose
# and forwarded into the container). Only set the one you'll use:
#   - API_KEY_ANTHROPIC for claude-opus-4-7 / claude-sonnet-4-6 / claude-haiku-4-5
#   - API_KEY_MISTRAL for mistral-large-latest / mistral-medium-latest /
#     ministral-8b-latest / ministral-3b-latest
API_KEY_ANTHROPIC=""
API_KEY_MISTRAL=""
