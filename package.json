{
  "name": "aisc-controls",
  "version": "0.1.0",
  "private": true,
  "description": "Manage AI compliance checklists: browse a library, answer each one against your AI system with readiness scoring, and track submissions through a Draft → Closed lifecycle.",
  "license": "Apache-2.0",
  "keywords": [
    "ai-act",
    "compliance",
    "checklist",
    "governance",
    "nextjs",
    "prisma"
  ],
  "engines": {
    "node": ">=18.18"
  },
  "scripts": {
    "predev": "node scripts/setup-once.mjs",
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "setup": "rm -f node_modules/.cache/aisc-controls/setup-done && node scripts/setup-once.mjs",
    "db:up": "docker compose up -d db",
    "db:down": "docker compose down",
    "db:reset": "prisma migrate reset --force",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:studio": "prisma studio",
    "db:seed": "prisma db seed",
    "examples:export": "tsx prisma/seed/export.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:unit": "vitest run test/unit"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "next": "^15.5.15",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "prisma": "^5.22.0",
    "tsx": "^4.21.0",
    "typescript": "^5.6.3",
    "vitest": "^2.1.9"
  },
  "overrides": {
    "postcss": "^8.5.10"
  }
}
