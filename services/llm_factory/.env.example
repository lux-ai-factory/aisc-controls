# Provider keys for the bundled LLMFactory service. Only the providers you
# plan to use need a key — leave the rest blank.

# Anthropic — required for claude-opus-4-7 / claude-sonnet-4-6 / claude-haiku-4-5
API_KEY_ANTHROPIC=

# Mistral — required for mistral-large-latest / mistral-medium-latest /
# ministral-8b-latest / ministral-3b-latest
API_KEY_MISTRAL=
